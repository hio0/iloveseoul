  eventname: "\uB9C8\uBC95\uC0AC"
  eventlog: "\uC641\uC790\uC9C0\uAEC4, \uBAA8\uC5EC \uC788\uB294 \uC0AC\uB78C\uB4E4\uC758
    \uBAA8\uC2B5\uC774 \uBCF4\uC778\uB2E4.\n\uC790\uC138\uD788 \uBCF4\uB2C8 \uADF8\uB4E4\uC740
    \uC2E0\uBE44\uB85C\uC6B4 \uC19C\uC528\uB85C \uAD00\uAC1D\uC744 \uAC10\uCABD\uAC19\uC774
    \uC18D\uC774\uB294 \uC5B4\uB290 \uB9C8\uC220\uC0AC\uC758 \uACF5\uC5F0\uC744 \uBCF4\uACE0\uC790
    \uBAA8\uC5EC\uC788\uB358 \uAC83\uC774\uC600\uB2E4.\n\uC0AC\uB78C\uB4E4\uC740
    \uAC10\uD0C4\uD558\uACE0, \uC6C3\uC73C\uBA70 \uB9C8\uBC95\uC0AC\uC758 \uB9C8\uC220\uC1FC\uC5D0
    \uC81C\uBC95 \uB9CC\uC871\uD558\uB294 \uB208\uCE58\uC774\uB2E4.\n\uB9C8\uBC95\uC0AC\uC5D0\uAC8C
    \uC18C\uC815\uC758 \uB3C8\uC744 \uC900\uB2E4\uBA74, \uC55E\uC73C\uB85C\uC758
    \uC9C0\uC5ED \uBC1C\uC804\uC5D0\uB3C4 \uBD84\uBA85\uD788 \uB3C4\uC6C0\uC774 \uB420
    \uAC83\uC774\uB2E4."
  correctlog: "\uB9C8\uBC95\uC0AC\uC5D0\uAC8C \uC870\uAE08\uC774\uB098\uB9C8 \uBCF4\uD0EC\uC774
    \uB418\uACE0\uC790 \uC18C\uC815\uC758 \uB3C8\uC744 \uC8FC\uC5C8\uB2E4. \uADF8\uB140
    \uB610\uD55C \uC870\uAE08\uC774\uB098\uB9C8 \uAE30\uBED0\uD558\uB294 \uB208\uCE58\uC774\uB2E4."
